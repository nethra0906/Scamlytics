{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "excludeFiles": "{venv/**,**/__pycache__/**,**/*.pyc,**/*.pyo,tests/**,.pytest_cache/**,scamlytics.log,app.db}"
    }
  }
}